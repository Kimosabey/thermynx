# ── Unicharm MySQL (read-only, Tailscale-reachable) ──────────────────────────
DB_HOST=<tailscale-ip-or-hostname>
DB_PORT=3307
DB_USER=ro_user
DB_PASSWORD=changeme
DB_NAME=unicharm

# ── Postgres thermynx_app (docker compose) ───────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://thermynx:dev@localhost:5432/thermynx_app
POSTGRES_PASSWORD=dev

# ── Redis (docker compose) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Ollama (Tailscale server, RTX 4000 Ada) ──────────────────────────────────
OLLAMA_HOST=http://100.125.103.28:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:14b

# ── App ───────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000

# ── Logging (optional) ─────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# One JSON object per line on stdout (good for Loki / Cloud Logging)
LOG_JSON=false
# HTTP access line per request (method path status ms request_id)
LOG_ACCESS=true
# Echo SQLAlchemy SQL to logs (very noisy; pair with LOG_LEVEL=DEBUG)
LOG_SQL_ECHO=false
