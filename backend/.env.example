# Backend environment (copy to `.env`). See `app/config.py` for full schema.

# MySQL telemetry (normalized plant tables)
# DB_HOST=localhost
# DB_PORT=3307
# DB_USER=root
# DB_PASSWORD=changeme
# DB_NAME=unicharm

# Anchor time windows for telemetry queries:
# - latest_in_db — each *_normalized table uses its own MAX(slot_time) as window end (old dumps; default).
# - wall_clock   — window ends at UTC now (live feeds).
# TELEMETRY_TIME_ANCHOR=latest_in_db

# Comma-separated browser origins allowed to call the API (required in production).
# CORS_ORIGINS=https://app.yourdomain.com,https://staging.yourdomain.com

# Optional: require X-API-Key (or Authorization: Bearer …) on API routes when non-empty.
# API_KEYS=secret-one,secret-two
