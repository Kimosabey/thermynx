# Backend environment (copy to `.env`). See `app/config.py` for full schema.

# ── MySQL telemetry (normalized plant tables) ────────────────────────────────
# DB_HOST=localhost
# DB_PORT=3307
# DB_USER=root
# DB_PASSWORD=changeme
# DB_NAME=unicharm

# Anchor time windows for telemetry queries:
# - latest_in_db — each *_normalized table uses its own MAX(slot_time) as window end (old dumps; default).
# - wall_clock   — window ends at UTC now (live feeds).
# TELEMETRY_TIME_ANCHOR=latest_in_db

# ── CORS / API key gate ──────────────────────────────────────────────────────
# Comma-separated browser origins allowed to call the API (required in production).
# CORS_ORIGINS=https://app.yourdomain.com,https://staging.yourdomain.com

# Optional: require X-API-Key (or Authorization: Bearer …) on API routes when non-empty.
# API_KEYS=secret-one,secret-two

# ── Logging & observability ──────────────────────────────────────────────────
# Level: DEBUG | INFO | WARNING | ERROR (default INFO)
# LOG_LEVEL=INFO

# Emit structured JSON on stdout — recommended in any deployed environment.
# LOG_JSON=true

# HTTP access log line per request (default true).
# LOG_ACCESS=true

# SQLAlchemy query echo (very verbose — DEBUG only).
# LOG_SQL_ECHO=false

# Write logs to a rotating JSON file in addition to stdout. Required for
# Promtail to ship backend logs into Loki when uvicorn runs on the host (not
# in Docker). Leave empty to disable file logging.
#
# The ./logs directory is bind-mounted into the promtail container at
# /var/log/graylinx by docker-compose.yml, so files matching ./logs/*.log are
# picked up automatically. See docs/operations/OBSERVABILITY.md § 7.
# LOG_FILE=./logs/graylinx-api.log
# LOG_FILE_MAX_BYTES=10485760    # 10 MB per file before rotation
# LOG_FILE_BACKUP_COUNT=5        # keep last 5 rotated files
