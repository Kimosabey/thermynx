{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "stat",
      "title": "Agent runs (last 1h)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(graylinx_agent_runs_total[1h]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "type": "stat",
      "title": "Analyzer requests (last 1h)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(graylinx_analyzer_requests_total[1h]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "fixed", "fixedColor": "purple" } } }
    },
    {
      "type": "stat",
      "title": "Anomalies detected (last 24h)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(graylinx_anomalies_detected_total[24h]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] } } }
    },
    {
      "type": "stat",
      "title": "Agent error rate (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(graylinx_agent_runs_total{status=\"error\"}[5m])) / clamp_min(sum(rate(graylinx_agent_runs_total[5m])), 0.001)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.2 }] } } }
    },
    {
      "type": "timeseries",
      "title": "Agent runs by mode",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (mode) (rate(graylinx_agent_runs_total[5m]))", "refId": "A", "legendFormat": "{{mode}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 12, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Agent run status mix",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (status) (rate(graylinx_agent_runs_total[5m]))", "refId": "A", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 70, "stacking": { "mode": "normal" } } } }
    },
    {
      "type": "timeseries",
      "title": "Analyzer p99 latency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"thermynx-api\",handler=\"/api/v1/analyze\"}[5m])))", "refId": "A", "legendFormat": "/analyze p99" },
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"thermynx-api\",handler=\"/api/v1/analyze\"}[5m])))", "refId": "B", "legendFormat": "/analyze p50" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 2, "custom": { "drawStyle": "line", "lineWidth": 2 } } }
    },
    {
      "type": "timeseries",
      "title": "Anomalies by equipment (1h trailing)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (equipment_id) (increase(graylinx_anomalies_detected_total[1h]))", "refId": "A", "legendFormat": "{{equipment_id}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 70 } } }
    },
    {
      "type": "logs",
      "title": "Recent agent + analyzer events",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{service=\"api\"} | json | logger=~\"thermynx.services.agent|thermynx.api.analyzer|thermynx.llm.ollama\"", "refId": "A" }
      ],
      "options": { "showTime": true, "showLabels": false, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["graylinx", "ai", "agent"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Graylinx — AI Operations",
  "uid": "graylinx-ai-operations",
  "version": 1
}
