#!/bin/sh
# Pre-push reminder (F6.8) — the golden eval is NOT run automatically on push.
#
# WHY NOT: the golden suite makes ~50 live LLM calls. On the shared 20 GB GPU,
# running it on every push floods/thrashes the box (50 model calls queue + the
# models can't co-reside, so they evict/cold-load constantly) — it starved the
# GPU and wedged the box. A pre-push LLM gate only belongs on a dedicated CI GPU
# / the 48 GB box, not a shared 20 GB dev box.
#
# So this hook just reminds you to run the gate MANUALLY before a release:
#   cd backend && PYTHONIOENCODING=utf-8 ../.venv/Scripts/python -m pytest tests/eval/test_golden.py -q
#
# (Fast deterministic guard cases — refusals/injection, no LLM — could be wired
# here later as a quick non-flooding gate; the full LLM suite should be CI-only.)

echo "[pre-push] golden eval is NOT auto-run (it floods the shared 20 GB GPU)."
echo "[pre-push] run it manually before a release:"
echo "[pre-push]   cd backend && PYTHONIOENCODING=utf-8 ../.venv/Scripts/python -m pytest tests/eval/test_golden.py -q"
exit 0
