#!/bin/sh
# Pre-push AI eval gate (F6.8).
#
# Runs the golden suite before every push so a prompt/agent/model regression
# can't be pushed silently. Skips gracefully when the backend isn't running
# locally (no false blocks); blocks only on a real test failure.
#
# Activate once per clone:   git config core.hooksPath .githooks
# Bypass for an emergency push:  git push --no-verify

echo "[pre-push] AI eval gate -> make eval"
if ! command -v make >/dev/null 2>&1; then
  echo "[pre-push] 'make' not found; skipping eval gate."
  exit 0
fi

make eval
if [ $? -ne 0 ]; then
  echo "[pre-push] eval gate FAILED -> push blocked. Run 'make eval' to see which golden case regressed."
  echo "[pre-push] (emergency override: git push --no-verify)"
  exit 1
fi
echo "[pre-push] eval gate passed."
exit 0
