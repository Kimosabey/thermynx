# Frontend env (copy to `.env` or `.env.local`; restart `npm run dev` after changes).

# Optional: send X-API-Key on every browser request when backend `API_KEYS` is configured.
# VITE_API_KEY=your-local-dev-key

# Dashboard telemetry window: API keeps rows with slot_time >= UTC now − N hours.
# Increase when MySQL is an older snapshot (not real-time). Backend caps at 8760 (~1y).
# VITE_EQUIPMENT_SUMMARY_HOURS=720
